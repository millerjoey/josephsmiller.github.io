{
  "id": "machine_health",
  "title": "Machine Health (synthetic data)",
  "subtitle": "Synthetic equipment data with one-sided sensor limits and set-valued alarm states.",
  "about": "Synthetic, hand-authored demonstration model. It is not trained on a real equipment dataset yet; the parameters are chosen to mimic operating regimes with sensor limits, alarm states, count data, and zero-inflated downtime.",
  "features": [
    {
      "name": "mode",
      "label": "Mode",
      "kind": "categorical",
      "values": ["nominal", "strained", "failing", "recovering"]
    },
    {
      "name": "load_pct",
      "label": "Load",
      "kind": "continuous",
      "domain": [10, 100],
      "unit": "%",
      "bins": 10
    },
    {
      "name": "temperature_c",
      "label": "Temperature",
      "kind": "continuous",
      "domain": [35, 110],
      "unit": "C",
      "bins": 10
    },
    {
      "name": "vibration",
      "label": "Vibration",
      "kind": "continuous",
      "domain": [0, 25],
      "unit": "mm/s",
      "bins": 10
    },
    {
      "name": "cycles",
      "label": "Cycles",
      "kind": "count",
      "domain": [0, 30],
      "unit": "cycles",
      "bins": 10
    },
    {
      "name": "alarm",
      "label": "Alarm",
      "kind": "categorical",
      "values": ["none", "watch", "action"]
    },
    {
      "name": "downtime_h",
      "label": "Downtime",
      "kind": "continuous",
      "domain": [0, 72],
      "unit": "hours",
      "bins": 12
    }
  ],
  "presets": [
    {
      "name": "Hot Sensor",
      "evidence": {
        "temperature_c": { "kind": "interval", "lower": 82 },
        "vibration": { "kind": "interval", "upper": 8 },
        "alarm": { "kind": "set", "values": ["watch", "action"] }
      }
    },
    {
      "name": "Censored Downtime",
      "evidence": {
        "downtime_h": { "kind": "interval", "upper": 2 },
        "load_pct": { "kind": "interval", "lower": 65 },
        "alarm": { "kind": "exact", "value": "none" }
      }
    },
    {
      "name": "Failure Search",
      "evidence": {
        "vibration": { "kind": "interval", "lower": 12 },
        "temperature_c": { "kind": "interval", "lower": 78 },
        "cycles": { "kind": "interval", "lower": 14 }
      }
    }
  ],
  "root": {
    "type": "sum",
    "name": "fleet",
    "weights": [0.5, 0.25, 0.12, 0.13],
    "children": [
      {
        "type": "product",
        "name": "nominal",
        "children": [
          { "type": "leaf", "feature": "mode", "dist": { "kind": "categorical", "probs": { "nominal": 0.9, "strained": 0.07, "failing": 0.01, "recovering": 0.02 } } },
          { "type": "leaf", "feature": "load_pct", "dist": { "kind": "normal", "mean": 52, "sd": 14 } },
          { "type": "leaf", "feature": "temperature_c", "dist": { "kind": "normal", "mean": 58, "sd": 6 } },
          { "type": "leaf", "feature": "vibration", "dist": { "kind": "lognormal", "mu": 0.65, "sigma": 0.35 } },
          { "type": "leaf", "feature": "cycles", "dist": { "kind": "poisson", "lambda": 5.5 } },
          { "type": "leaf", "feature": "alarm", "dist": { "kind": "categorical", "probs": { "none": 0.86, "watch": 0.12, "action": 0.02 } } },
          { "type": "leaf", "feature": "downtime_h", "dist": { "kind": "zeroInflatedLognormal", "zeroProb": 0.78, "mu": 0.2, "sigma": 0.65 } }
        ]
      },
      {
        "type": "product",
        "name": "strained",
        "children": [
          { "type": "leaf", "feature": "mode", "dist": { "kind": "categorical", "probs": { "nominal": 0.08, "strained": 0.82, "failing": 0.06, "recovering": 0.04 } } },
          { "type": "leaf", "feature": "load_pct", "dist": { "kind": "normal", "mean": 75, "sd": 11 } },
          { "type": "leaf", "feature": "temperature_c", "dist": { "kind": "normal", "mean": 73, "sd": 7 } },
          { "type": "leaf", "feature": "vibration", "dist": { "kind": "lognormal", "mu": 1.55, "sigma": 0.38 } },
          { "type": "leaf", "feature": "cycles", "dist": { "kind": "poisson", "lambda": 9.5 } },
          { "type": "leaf", "feature": "alarm", "dist": { "kind": "categorical", "probs": { "none": 0.32, "watch": 0.54, "action": 0.14 } } },
          { "type": "leaf", "feature": "downtime_h", "dist": { "kind": "zeroInflatedLognormal", "zeroProb": 0.48, "mu": 1.3, "sigma": 0.75 } }
        ]
      },
      {
        "type": "product",
        "name": "failing",
        "children": [
          { "type": "leaf", "feature": "mode", "dist": { "kind": "categorical", "probs": { "nominal": 0.01, "strained": 0.08, "failing": 0.87, "recovering": 0.04 } } },
          { "type": "leaf", "feature": "load_pct", "dist": { "kind": "normal", "mean": 82, "sd": 10 } },
          { "type": "leaf", "feature": "temperature_c", "dist": { "kind": "normal", "mean": 88, "sd": 8 } },
          { "type": "leaf", "feature": "vibration", "dist": { "kind": "lognormal", "mu": 2.55, "sigma": 0.42 } },
          { "type": "leaf", "feature": "cycles", "dist": { "kind": "poisson", "lambda": 15.0 } },
          { "type": "leaf", "feature": "alarm", "dist": { "kind": "categorical", "probs": { "none": 0.05, "watch": 0.25, "action": 0.7 } } },
          { "type": "leaf", "feature": "downtime_h", "dist": { "kind": "zeroInflatedLognormal", "zeroProb": 0.16, "mu": 2.6, "sigma": 0.72 } }
        ]
      },
      {
        "type": "product",
        "name": "recovering",
        "children": [
          { "type": "leaf", "feature": "mode", "dist": { "kind": "categorical", "probs": { "nominal": 0.08, "strained": 0.12, "failing": 0.08, "recovering": 0.72 } } },
          { "type": "leaf", "feature": "load_pct", "dist": { "kind": "normal", "mean": 46, "sd": 12 } },
          { "type": "leaf", "feature": "temperature_c", "dist": { "kind": "normal", "mean": 64, "sd": 8 } },
          { "type": "leaf", "feature": "vibration", "dist": { "kind": "lognormal", "mu": 1.2, "sigma": 0.42 } },
          { "type": "leaf", "feature": "cycles", "dist": { "kind": "poisson", "lambda": 7.0 } },
          { "type": "leaf", "feature": "alarm", "dist": { "kind": "categorical", "probs": { "none": 0.58, "watch": 0.34, "action": 0.08 } } },
          { "type": "leaf", "feature": "downtime_h", "dist": { "kind": "zeroInflatedLognormal", "zeroProb": 0.56, "mu": 0.95, "sigma": 0.7 } }
        ]
      }
    ]
  }
}
